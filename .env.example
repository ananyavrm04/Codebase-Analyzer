# ── LLM Providers ──────────────────────────────────────────────────────────
# Primary: Groq (free, fastest)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback 1: Together AI
TOGETHER_API_KEY=your_together_key
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Fallback 2: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Embedding Provider ─────────────────────────────────────────────────────
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
# OPENAI_API_KEY=sk-...    # only if EMBEDDING_PROVIDER=openai

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate Limiting (nothing hardcoded — all configurable) ───────────────────
RATE_LIMIT_MAX=10           # max API requests per window per IP
RATE_LIMIT_WINDOW=60        # window in seconds

GROQ_RATE_LIMIT=5           # max Groq LLM calls per window
GROQ_RATE_WINDOW=60         # window in seconds

# ── Storage ────────────────────────────────────────────────────────────────
INDEX_DIR=.indexes
